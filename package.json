{
  "name": "apex-pack-tracker",
  "version": "1.0.0",
  "description": "Apex Legends Heirloom Pack Tracker with Telegram WebApp and Firebase support",
  "scripts": {
    "build": "tsc && tsc firebase.ts --outFile firebase.js --target ES2017",
    "watch": "tsc --watch",
    "serve": "npx serve .",
    "dev": "concurrently \"npm run watch\" \"npm run serve\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d .",
    "deploy:firebase": "firebase deploy --only hosting"
  },
  "keywords": [
    "apex-legends",
    "pack-tracker",
    "telegram-webapp",
    "firebase"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "gh-pages": "^6.1.0",
    "serve": "^14.2.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_USERNAME/apex-pack-tracker.git"
  }
}
